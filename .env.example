HOST=127.0.0.1
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

POLYGON_RPC_URL=https://polygon-rpc.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# Gere um segredo forte (>=64 bytes random hex) na primeira execução:
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-on-first-run
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=15

# Opcional: API key da agregadora The Odds API (https://the-odds-api.com)
THE_ODDS_API_KEY=
